{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harvard-edge.github.io/architecture2/labs/ai-systolic-proposal.v1.schema.json",
  "title": "Recorded model proposal for the Architecture 2.0 SCALE-Sim study",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "proposal_id",
    "candidates",
    "global_mechanism_hypothesis",
    "discriminating_test",
    "evidence_boundary"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "arch2-ai-proposal/v1"
    },
    "proposal_id": {
      "type": "string",
      "const": "recorded_model_arm"
    },
    "candidates": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_id",
          "array_rows",
          "array_cols",
          "expected_qualitative_behavior",
          "mechanism_hypothesis",
          "anticipated_failure_mode",
          "rationale"
        ],
        "properties": {
          "candidate_id": {
            "type": "string",
            "pattern": "^ai_[a-z0-9][a-z0-9_]*$"
          },
          "array_rows": {
            "type": "integer",
            "enum": [8, 16, 32, 64, 128]
          },
          "array_cols": {
            "type": "integer",
            "enum": [8, 16, 32, 64, 128]
          },
          "expected_qualitative_behavior": {
            "type": "string",
            "minLength": 20
          },
          "mechanism_hypothesis": {
            "type": "string",
            "minLength": 30
          },
          "anticipated_failure_mode": {
            "type": "string",
            "minLength": 20
          },
          "rationale": {
            "type": "string",
            "minLength": 40
          }
        }
      }
    },
    "global_mechanism_hypothesis": {
      "type": "string",
      "minLength": 50
    },
    "discriminating_test": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "original_workload_prediction",
        "transposed_workload_prediction",
        "falsifier"
      ],
      "properties": {
        "original_workload_prediction": {
          "type": "string",
          "minLength": 30
        },
        "transposed_workload_prediction": {
          "type": "string",
          "minLength": 30
        },
        "falsifier": {
          "type": "string",
          "minLength": 30
        }
      }
    },
    "evidence_boundary": {
      "type": "string",
      "minLength": 50
    }
  }
}
