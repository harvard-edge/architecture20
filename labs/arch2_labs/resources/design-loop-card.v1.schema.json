{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arch2.mlsysbook.ai/schemas/design-loop-card.v1.schema.json",
  "title": "Architecture 2.0 Design-Loop Card",
  "description": "Version 1.0 of the canonical machine contract for the twelve-field Architecture 2.0 design-loop card.",
  "type": "object",
  "required": ["schema_version", "design_loop_card"],
  "properties": {
    "schema_version": {
      "const": "1.0",
      "description": "Contract version. This is document metadata, not a thirteenth card field."
    },
    "design_loop_card": {
      "$ref": "#/$defs/card"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "stringArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "intent": {
      "type": "object",
      "required": ["objective", "constraints", "non_goals"],
      "properties": {
        "objective": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "constraints": {
          "$ref": "#/$defs/stringArray"
        },
        "non_goals": {
          "$ref": "#/$defs/stringArray"
        },
        "risks": {
          "$ref": "#/$defs/stringArray"
        },
        "deployment_assumptions": {
          "$ref": "#/$defs/stringArray"
        },
        "claim_boundary": {
          "type": "object",
          "description": "Optional research-paper view of the intent. It records the claim and non-claim without creating another top-level card field.",
          "required": ["claim", "non_claim"],
          "properties": {
            "claim": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "non_claim": {
              "$ref": "#/$defs/nonEmptyString"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "designSpace": {
      "type": "object",
      "required": ["legal", "invalid", "deferred"],
      "properties": {
        "legal": {
          "$ref": "#/$defs/stringArray"
        },
        "invalid": {
          "$ref": "#/$defs/stringArray"
        },
        "deferred": {
          "$ref": "#/$defs/stringArray"
        }
      },
      "additionalProperties": false
    },
    "representation": {
      "type": "object",
      "required": ["ir_level", "reads", "writes", "uncertainties"],
      "properties": {
        "state_schema_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "ir_level": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "reads": {
          "$ref": "#/$defs/stringArray"
        },
        "writes": {
          "$ref": "#/$defs/stringArray"
        },
        "uncertainties": {
          "$ref": "#/$defs/stringArray"
        }
      },
      "additionalProperties": false
    },
    "environment": {
      "type": "object",
      "required": ["actions", "invalid_actions", "blast_radius_limit", "observations", "fidelity"],
      "properties": {
        "environment_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "actions": {
          "$ref": "#/$defs/stringArray"
        },
        "invalid_actions": {
          "$ref": "#/$defs/stringArray"
        },
        "blast_radius_limit": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "observations": {
          "$ref": "#/$defs/stringArray"
        },
        "fidelity": {
          "enum": [
            "proxy",
            "simulation",
            "rtl",
            "synthesis_with_sdc",
            "silicon",
            "shadow_traffic",
            "canary",
            "global_fleet"
          ]
        }
      },
      "additionalProperties": false
    },
    "actor": {
      "type": "object",
      "required": ["actor_id", "role", "reads", "writes", "authority"],
      "properties": {
        "actor_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "role": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "reads": {
          "$ref": "#/$defs/stringArray"
        },
        "writes": {
          "$ref": "#/$defs/stringArray"
        },
        "authority": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": false
    },
    "methodRole": {
      "type": "object",
      "required": ["roles"],
      "properties": {
        "roles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["generate", "predict", "optimize", "critique", "verify", "plan", "tool_call", "coordinate"]
          }
        },
        "actor_map": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/actor"
          }
        }
      },
      "additionalProperties": false
    },
    "modelSideCost": {
      "type": "object",
      "required": ["model_calls", "gpu_hours", "energy_or_carbon", "human_review"],
      "properties": {
        "model_calls": {
          "type": "integer",
          "minimum": 0
        },
        "gpu_hours": {
          "type": "number",
          "minimum": 0
        },
        "energy_or_carbon": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "human_review": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": false
    },
    "feedbackBudget": {
      "type": "object",
      "required": ["evaluations", "latency", "cost", "fidelity"],
      "properties": {
        "evaluations": {
          "type": "integer",
          "minimum": 0
        },
        "latency": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "cost": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "fidelity": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "model_side_cost": {
          "$ref": "#/$defs/modelSideCost"
        }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": ["tool_version", "parameter_hash"],
      "properties": {
        "tool_version": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "parameter_hash": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "source_uri": {
          "type": "string",
          "format": "uri-reference"
        },
        "recorded_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "evidenceRecord": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "evidence_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "kind": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "workload_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "seed": {
          "oneOf": [
            {"type": "integer"},
            {"$ref": "#/$defs/nonEmptyString"}
          ]
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        }
      },
      "additionalProperties": false
    },
    "resourceBoundary": {
      "type": "object",
      "required": ["operational_energy", "embodied_or_manufacturing_scope", "geography_or_time_basis", "utilization_or_amortization_basis"],
      "properties": {
        "operational_energy": {"$ref": "#/$defs/nonEmptyString"},
        "embodied_or_manufacturing_scope": {"$ref": "#/$defs/nonEmptyString"},
        "geography_or_time_basis": {"$ref": "#/$defs/nonEmptyString"},
        "utilization_or_amortization_basis": {"$ref": "#/$defs/nonEmptyString"}
      },
      "additionalProperties": false
    },
    "telemetryPacket": {
      "type": "object",
      "required": ["hardware_stepping", "software_stack", "deployment_version", "cohort", "sampling_policy", "privacy_filter", "canary_or_rollback_label", "incident_context", "decision_owner"],
      "properties": {
        "hardware_stepping": {"$ref": "#/$defs/nonEmptyString"},
        "software_stack": {"$ref": "#/$defs/nonEmptyString"},
        "deployment_version": {"$ref": "#/$defs/nonEmptyString"},
        "cohort": {"$ref": "#/$defs/nonEmptyString"},
        "sampling_policy": {"$ref": "#/$defs/nonEmptyString"},
        "privacy_filter": {"$ref": "#/$defs/nonEmptyString"},
        "canary_or_rollback_label": {"$ref": "#/$defs/nonEmptyString"},
        "incident_context": {"$ref": "#/$defs/nonEmptyString"},
        "decision_owner": {"$ref": "#/$defs/nonEmptyString"}
      },
      "additionalProperties": false
    },
    "integrityManifest": {
      "type": "object",
      "required": ["dependencies", "model_ids", "prompt_ids", "artifact_hashes", "attestations"],
      "properties": {
        "dependencies": {"$ref": "#/$defs/stringArray"},
        "model_ids": {"$ref": "#/$defs/stringArray"},
        "prompt_ids": {"$ref": "#/$defs/stringArray"},
        "artifact_hashes": {"$ref": "#/$defs/stringArray"},
        "attestations": {"$ref": "#/$defs/stringArray"}
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "required": ["baseline_id", "records"],
      "properties": {
        "baseline_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "records": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidenceRecord"
          }
        },
        "resource_or_sustainability_boundary": {
          "$ref": "#/$defs/resourceBoundary"
        },
        "telemetry_packet": {
          "$ref": "#/$defs/telemetryPacket"
        },
        "integrity_manifest": {
          "$ref": "#/$defs/integrityManifest"
        }
      },
      "additionalProperties": false
    },
    "negativeTrace": {
      "type": "object",
      "required": ["reason", "stage", "gate"],
      "properties": {
        "candidate_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "reason": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "stage": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "gate": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": false
    },
    "disclosureBoundary": {
      "type": "object",
      "required": ["data_classes", "redactions", "reviewer_roles", "release_boundary_or_compliance_review_id"],
      "properties": {
        "data_classes": {"$ref": "#/$defs/stringArray"},
        "redactions": {"$ref": "#/$defs/stringArray"},
        "reviewer_roles": {"$ref": "#/$defs/stringArray"},
        "release_boundary_or_compliance_review_id": {"$ref": "#/$defs/nonEmptyString"}
      },
      "additionalProperties": false
    },
    "rejectionAuthority": {
      "type": "object",
      "required": ["gates", "independent_of_producer", "independence_basis"],
      "properties": {
        "gates": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/nonEmptyString"}
        },
        "independent_of_producer": {
          "type": "boolean"
        },
        "independence_basis": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": false
    },
    "commitmentBoundary": {
      "type": "object",
      "required": ["level", "strongest_supported_claim", "would_overturn"],
      "properties": {
        "level": {
          "enum": ["exploratory", "experimental", "implementation", "integration", "irreversible"]
        },
        "strongest_supported_claim": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "would_overturn": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": false
    },
    "humanDecision": {
      "type": "object",
      "required": ["owner", "authorizes"],
      "properties": {
        "owner": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "authorizes": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": false
    },
    "card": {
      "type": "object",
      "required": ["card_id", "conformance_level", "intent", "task", "design_space"],
      "properties": {
        "card_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "conformance_level": {
          "type": "integer",
          "enum": [0, 1, 2, 3]
        },
        "intent": {
          "$ref": "#/$defs/intent"
        },
        "task": {
          "enum": ["generation", "prediction", "optimization", "critique", "verification", "characterization", "benchmark", "dse"]
        },
        "design_space": {
          "$ref": "#/$defs/designSpace"
        },
        "representation": {
          "$ref": "#/$defs/representation"
        },
        "environment": {
          "$ref": "#/$defs/environment"
        },
        "method_role": {
          "$ref": "#/$defs/methodRole"
        },
        "feedback_budget": {
          "$ref": "#/$defs/feedbackBudget"
        },
        "evidence": {
          "$ref": "#/$defs/evidence"
        },
        "negative_traces": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/negativeTrace"
          }
        },
        "disclosure_boundary": {
          "$ref": "#/$defs/disclosureBoundary"
        },
        "rejection_authority": {
          "$ref": "#/$defs/rejectionAuthority"
        },
        "commitment_boundary": {
          "$ref": "#/$defs/commitmentBoundary"
        },
        "human_decision": {
          "$ref": "#/$defs/humanDecision"
        }
      },
      "patternProperties": {
        "^x-[a-z0-9][a-z0-9.-]*$": {}
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "conformance_level": {"minimum": 1}
            },
            "required": ["conformance_level"]
          },
          "then": {
            "required": ["representation", "environment", "method_role", "feedback_budget", "evidence", "negative_traces"]
          }
        },
        {
          "if": {
            "properties": {
              "conformance_level": {"minimum": 2}
            },
            "required": ["conformance_level"]
          },
          "then": {
            "properties": {
              "representation": {
                "required": ["state_schema_id"]
              },
              "environment": {
                "required": ["environment_id"]
              },
              "evidence": {
                "properties": {
                  "records": {
                    "items": {
                      "required": ["evidence_id", "workload_id", "seed", "provenance"]
                    }
                  }
                }
              },
              "negative_traces": {
                "items": {
                  "required": ["candidate_id"]
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "conformance_level": {"const": 3}
            },
            "required": ["conformance_level"]
          },
          "then": {
            "required": ["rejection_authority", "commitment_boundary", "human_decision"],
            "properties": {
              "rejection_authority": {
                "properties": {
                  "independent_of_producer": {"const": true}
                }
              }
            }
          }
        }
      ]
    }
  }
}
