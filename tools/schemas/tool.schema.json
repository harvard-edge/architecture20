{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arch2.mlsysbook.ai/schemas/tool-registry.v1.schema.json",
  "title": "Architecture 2.0 Tool Registry Entry",
  "type": "object",
  "required": ["title", "url", "artifact_type", "categories", "description", "fit_note", "artifact_availability"],
  "properties": {
    "title": {"type": "string", "minLength": 1},
    "url": {"type": "string", "format": "uri", "pattern": "^https?://"},
    "artifact_type": {
      "enum": ["Tool", "Dataset", "Benchmark", "Evaluation Harness", "Design Loop", "Tutorial or Example", "Other"]
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": ["Simulation", "Proxy Models", "Agentic Workflows", "Data Representations", "Verification", "Benchmarks and Datasets", "Physical Design"]
      }
    },
    "description": {"type": "string", "minLength": 1, "maxLength": 220},
    "fit_note": {"type": "string", "minLength": 1, "maxLength": 180},
    "artifact_availability": {
      "enum": ["runnable", "source_available", "benchmark_available", "dataset_available", "paper_only", "unverified"]
    },
    "last_verified": {
      "oneOf": [
        {"type": "string", "format": "date"},
        {"type": "null"}
      ]
    },
    "verification_note": {"type": "string", "minLength": 1},
    "authors": {"type": "string", "minLength": 1},
    "institution": {"type": "string", "minLength": 1},
    "submitted_by": {"type": "string", "minLength": 1},
    "inputs": {"type": "string", "minLength": 1},
    "outputs": {"type": "string", "minLength": 1},
    "evidence": {"type": "string", "minLength": 1},
    "limitations": {"type": "string", "minLength": 1},
    "paper_url": {"type": "string", "format": "uri", "pattern": "^https?://"},
    "docs_url": {"type": "string", "format": "uri", "pattern": "^https?://"},
    "artifact_url": {"type": "string", "format": "uri", "pattern": "^https?://"},
    "license": {"type": "string", "minLength": 1},
    "citation": {"type": "string", "minLength": 1},
    "status": {
      "enum": ["Active project", "Published artifact", "Preprint or paper artifact", "Prototype", "Dataset or benchmark", "Other"]
    },
    "category_suggestion": {"type": "string", "minLength": 1},
    "maintainer_note": {"type": "string", "minLength": 1},
    "order": {"type": "integer", "minimum": 0},
    "tags": {
      "type": "array",
      "maxItems": 5,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "maxLength": 32}
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {"artifact_availability": {"const": "unverified"}},
        "required": ["artifact_availability"]
      },
      "then": {"properties": {"last_verified": {"type": "null"}}},
      "else": {
        "required": ["last_verified"],
        "properties": {"last_verified": {"type": "string", "format": "date"}}
      }
    },
    {
      "if": {
        "properties": {"artifact_availability": {"const": "runnable"}},
        "required": ["artifact_availability"]
      },
      "then": {"required": ["verification_note"]}
    }
  ]
}
