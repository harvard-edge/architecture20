{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arch2.mlsysbook.ai/schemas/design-loop-card.v2.schema.json",
  "title": "Architecture 2.0 Design-Loop Card",
  "description": "Version 2.0 of the Architecture 2.0 design-loop card. It binds claims, evidence, predeclared rejection checks, replay, and decision rights. Profiles are independent, and schema validity does not establish evidence quality.",
  "type": "object",
  "required": ["schema_version", "design_loop_card"],
  "properties": {
    "schema_version": {
      "const": "2.0",
      "description": "Contract version. This is document metadata, not a card field."
    },
    "design_loop_card": {
      "$ref": "#/$defs/card"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "extensionName": {
      "type": "string",
      "pattern": "^x-[a-z0-9][a-z0-9.-]*$"
    },
    "profileState": {
      "enum": ["complete", "partial", "not_claimed"]
    },
    "profiles": {
      "type": "object",
      "required": [
        "context",
        "inspectability",
        "replay",
        "independent_review",
        "disclosure",
        "decision_rights"
      ],
      "properties": {
        "context": {
          "const": "complete"
        },
        "inspectability": {
          "$ref": "#/$defs/profileState"
        },
        "replay": {
          "$ref": "#/$defs/profileState"
        },
        "independent_review": {
          "$ref": "#/$defs/profileState"
        },
        "disclosure": {
          "$ref": "#/$defs/profileState"
        },
        "decision_rights": {
          "$ref": "#/$defs/profileState"
        }
      },
      "additionalProperties": false
    },
    "profileGaps": {
      "type": "object",
      "properties": {
        "inspectability": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "replay": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "independent_review": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "disclosure": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "decision_rights": {
          "$ref": "#/$defs/nonEmptyStringArray"
        }
      },
      "additionalProperties": false
    },
    "intent": {
      "type": "object",
      "required": ["objective", "constraints", "non_goals"],
      "properties": {
        "objective": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "constraints": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "non_goals": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "risks": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "deployment_assumptions": {
          "$ref": "#/$defs/nonEmptyStringArray"
        }
      },
      "additionalProperties": false
    },
    "task": {
      "type": "object",
      "required": ["kind", "description"],
      "properties": {
        "kind": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$",
          "description": "An open task identifier. Use a stable local name instead of relying on a closed global enumeration."
        },
        "description": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "patternProperties": {
        "^x-[a-z0-9][a-z0-9.-]*$": {}
      },
      "additionalProperties": false
    },
    "designSpace": {
      "type": "object",
      "required": ["legal", "invalid", "deferred"],
      "properties": {
        "legal": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "invalid": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "deferred": {
          "$ref": "#/$defs/nonEmptyStringArray"
        }
      },
      "additionalProperties": false
    },
    "representation": {
      "type": "object",
      "required": ["state_schema_id", "abstraction", "reads", "writes", "uncertainties"],
      "properties": {
        "state_schema_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "abstraction": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "reads": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "writes": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "uncertainties": {
          "$ref": "#/$defs/nonEmptyStringArray"
        }
      },
      "patternProperties": {
        "^x-[a-z0-9][a-z0-9.-]*$": {}
      },
      "additionalProperties": false
    },
    "environment": {
      "type": "object",
      "required": [
        "environment_id",
        "actions",
        "invalid_actions",
        "blast_radius_limit",
        "observations",
        "fidelity"
      ],
      "properties": {
        "environment_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "actions": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "invalid_actions": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "blast_radius_limit": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "observations": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "fidelity": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "patternProperties": {
        "^x-[a-z0-9][a-z0-9.-]*$": {}
      },
      "additionalProperties": false
    },
    "methodRole": {
      "type": "object",
      "required": ["actor_id", "actor_type", "roles", "reads", "writes", "limitations"],
      "properties": {
        "actor_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "actor_type": {
          "enum": ["person", "team", "model", "tool", "pipeline", "policy"]
        },
        "roles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "anyOf": [
              {
                "enum": [
                  "generate",
                  "predict",
                  "optimize",
                  "critique",
                  "verify",
                  "plan",
                  "tool_call",
                  "coordinate"
                ]
              },
              {
                "type": "string",
                "pattern": "^x-[a-z0-9][a-z0-9.-]*$"
              }
            ]
          }
        },
        "reads": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "writes": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "limitations": {
          "$ref": "#/$defs/nonEmptyStringArray"
        }
      },
      "patternProperties": {
        "^x-[a-z0-9][a-z0-9.-]*$": {}
      },
      "additionalProperties": false
    },
    "feedbackBudget": {
      "type": "object",
      "required": ["evaluations", "latency", "compute_or_tool_cost", "human_review", "fidelity"],
      "properties": {
        "evaluations": {
          "type": "integer",
          "minimum": 0
        },
        "latency": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "compute_or_tool_cost": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "human_review": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "fidelity": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "model_calls": {
          "type": "integer",
          "minimum": 0
        },
        "energy_or_carbon": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": false
    },
    "artifactIntegrity": {
      "oneOf": [
        {
          "type": "object",
          "required": ["sha256"],
          "properties": {
            "sha256": {
              "$ref": "#/$defs/sha256"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["not_applicable_reason"],
          "properties": {
            "not_applicable_reason": {
              "$ref": "#/$defs/nonEmptyString"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "artifactRef": {
      "type": "object",
      "required": ["artifact_id", "uri", "integrity"],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "uri": {
          "type": "string",
          "format": "uri-reference",
          "minLength": 1
        },
        "integrity": {
          "$ref": "#/$defs/artifactIntegrity"
        }
      },
      "additionalProperties": false
    },
    "replayArtifactRef": {
      "type": "object",
      "required": ["artifact_id", "uri", "sha256"],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "uri": {
          "type": "string",
          "format": "uri-reference",
          "minLength": 1
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      },
      "additionalProperties": false
    },
    "producer": {
      "type": "object",
      "required": ["producer_id", "producer_type"],
      "properties": {
        "producer_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "producer_type": {
          "enum": ["person", "team", "model", "tool", "pipeline", "policy"]
        }
      },
      "additionalProperties": false
    },
    "tool": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "version": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": false
    },
    "evidenceRecord": {
      "type": "object",
      "required": [
        "evidence_id",
        "producer",
        "kind",
        "status",
        "tool",
        "inputs",
        "outputs",
        "scope",
        "limitations",
        "integrity"
      ],
      "properties": {
        "evidence_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "producer": {
          "$ref": "#/$defs/producer"
        },
        "kind": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "status": {
          "enum": ["measured", "computed", "digitized", "illustrative", "author-judgment"]
        },
        "tool": {
          "$ref": "#/$defs/tool"
        },
        "inputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/artifactRef"
          }
        },
        "outputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/artifactRef"
          }
        },
        "scope": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "uncertainty": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "limitations": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "integrity": {
          "$ref": "#/$defs/artifactIntegrity"
        }
      },
      "patternProperties": {
        "^x-[a-z0-9][a-z0-9.-]*$": {}
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "required": ["records"],
      "properties": {
        "records": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidenceRecord"
          }
        }
      },
      "patternProperties": {
        "^x-[a-z0-9][a-z0-9.-]*$": {}
      },
      "additionalProperties": false
    },
    "claim": {
      "type": "object",
      "required": [
        "claim_id",
        "claim_type",
        "statement",
        "baseline_or_comparator",
        "outcome",
        "scope",
        "non_claims",
        "status",
        "evidence_refs"
      ],
      "properties": {
        "claim_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "claim_type": {
          "anyOf": [
            {
              "enum": ["architecture_outcome", "ai_contribution", "mechanism", "safety", "process"]
            },
            {
              "type": "string",
              "pattern": "^x-[a-z0-9][a-z0-9.-]*$"
            }
          ]
        },
        "statement": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "baseline_or_comparator": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "outcome": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "scope": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "non_claims": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "status": {
          "enum": [
            "proposed",
            "supported",
            "partially_supported",
            "not_supported",
            "null_result",
            "falsified",
            "inconclusive",
            "not_tested"
          ]
        },
        "evidence_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      },
      "patternProperties": {
        "^x-[a-z0-9][a-z0-9.-]*$": {}
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "not": {
                  "enum": ["proposed", "not_tested"]
                }
              }
            },
            "required": ["status"]
          },
          "then": {
            "properties": {
              "evidence_refs": {
                "minItems": 1
              }
            }
          }
        }
      ]
    },
    "failedOrRejected": {
      "type": "object",
      "required": ["record_id", "kind", "stage", "reason", "evidence_refs"],
      "properties": {
        "record_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "kind": {
          "enum": [
            "environment_failure",
            "invalid_candidate",
            "rejected_alternative",
            "failed_gate",
            "superseded"
          ]
        },
        "candidate_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "stage": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "reason": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "gate_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "evidence_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      },
      "patternProperties": {
        "^x-[a-z0-9][a-z0-9.-]*$": {}
      },
      "additionalProperties": false
    },
    "waiverRule": {
      "type": "object",
      "required": ["allowed"],
      "properties": {
        "allowed": {
          "type": "boolean"
        },
        "authority_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "conditions": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "allowed": {
                "const": true
              }
            },
            "required": ["allowed"]
          },
          "then": {
            "required": ["authority_id", "conditions"]
          }
        }
      ]
    },
    "gate": {
      "description": "One predeclared pass/fail rejection check. The retained term gate does not mean a workflow stage, design change, reviewer, or general quality goal.",
      "type": "object",
      "required": [
        "gate_id",
        "category",
        "criterion",
        "result",
        "authority_id",
        "waiver_rule",
        "evidence_refs",
        "disposition"
      ],
      "properties": {
        "gate_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "category": {
          "anyOf": [
            {
              "enum": [
                "legality",
                "functionality",
                "performance",
                "power",
                "area",
                "timing",
                "security",
                "reliability",
                "workload",
                "evidence",
                "process"
              ]
            },
            {
              "type": "string",
              "pattern": "^x-[a-z0-9][a-z0-9.-]*$"
            }
          ]
        },
        "criterion": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "result": {
          "enum": ["passed", "failed", "not_run", "waived"]
        },
        "authority_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "waiver_rule": {
          "$ref": "#/$defs/waiverRule"
        },
        "evidence_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "disposition": {
          "enum": ["continue", "reject", "revise", "escalate", "waive", "stop"]
        },
        "notes": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "patternProperties": {
        "^x-[a-z0-9][a-z0-9.-]*$": {}
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "result": {
                "enum": ["passed", "failed", "waived"]
              }
            },
            "required": ["result"]
          },
          "then": {
            "properties": {
              "evidence_refs": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "result": {
                "const": "waived"
              }
            },
            "required": ["result"]
          },
          "then": {
            "properties": {
              "waiver_rule": {
                "properties": {
                  "allowed": {
                    "const": true
                  }
                }
              }
            }
          }
        }
      ]
    },
    "decisionRight": {
      "type": "object",
      "required": ["action", "holder_id", "holder_type", "scope", "conditions"],
      "properties": {
        "action": {
          "enum": ["propose", "execute", "reject", "waive", "recommend", "commit"]
        },
        "holder_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "holder_type": {
          "enum": ["person", "team", "model", "tool", "pipeline", "policy"]
        },
        "scope": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "conditions": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "patternProperties": {
        "^x-[a-z0-9][a-z0-9.-]*$": {}
      },
      "additionalProperties": false
    },
    "recommendation": {
      "type": "object",
      "required": ["recommender_id", "action", "basis", "claim_refs", "authority_limit"],
      "properties": {
        "recommender_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "action": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "basis": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "claim_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "authority_limit": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": false
    },
    "accountableDecision": {
      "type": "object",
      "required": [
        "status",
        "holder_id",
        "action",
        "rationale",
        "claim_refs",
        "authorized_scope",
        "reopen_conditions"
      ],
      "properties": {
        "status": {
          "enum": ["pending", "authorized", "rejected", "deferred", "superseded"]
        },
        "holder_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "action": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "rationale": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "claim_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "authorized_scope": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "recorded_at": {
          "type": "string",
          "format": "date-time"
        },
        "reopen_conditions": {
          "$ref": "#/$defs/nonEmptyStringArray"
        }
      },
      "patternProperties": {
        "^x-[a-z0-9][a-z0-9.-]*$": {}
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "not": {
                  "const": "pending"
                }
              }
            },
            "required": ["status"]
          },
          "then": {
            "required": ["recorded_at"]
          }
        }
      ]
    },
    "replayCommand": {
      "type": "object",
      "required": ["command", "working_directory"],
      "properties": {
        "command": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "working_directory": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": false
    },
    "replay": {
      "type": "object",
      "required": [
        "commands",
        "environment_binding",
        "inputs",
        "outputs",
        "expected_status",
        "observed_status",
        "validation_status",
        "validated_at",
        "validator"
      ],
      "properties": {
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/replayCommand"
          }
        },
        "environment_binding": {
          "$ref": "#/$defs/replayArtifactRef"
        },
        "inputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/replayArtifactRef"
          }
        },
        "outputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/replayArtifactRef"
          }
        },
        "expected_status": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "observed_status": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "validation_status": {
          "enum": ["bindings_verified", "replay_verified", "failed"]
        },
        "validated_at": {
          "type": "string",
          "format": "date-time"
        },
        "validator": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "patternProperties": {
        "^x-[a-z0-9][a-z0-9.-]*$": {}
      },
      "additionalProperties": false
    },
    "independentReview": {
      "type": "object",
      "required": [
        "review_id",
        "reviewer_id",
        "independence_basis",
        "shared_dependencies",
        "conflicts",
        "result",
        "claim_refs",
        "evidence_refs"
      ],
      "properties": {
        "review_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "reviewer_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "independence_basis": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "shared_dependencies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "conflicts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "result": {
          "enum": ["accepted", "rejected", "revise", "inconclusive"]
        },
        "claim_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      },
      "additionalProperties": false
    },
    "disclosure": {
      "type": "object",
      "required": [
        "data_classes",
        "redactions",
        "reviewer_roles",
        "release_boundary_or_compliance_review_id"
      ],
      "properties": {
        "data_classes": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "redactions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "reviewer_roles": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "release_boundary_or_compliance_review_id": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": false
    },
    "card": {
      "type": "object",
      "required": [
        "card_id",
        "profiles",
        "profile_gaps",
        "intent",
        "task",
        "design_space",
        "claims",
        "evidence",
        "failed_or_rejected",
        "gates",
        "decision_rights",
        "accountable_decision"
      ],
      "properties": {
        "card_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "profiles": {
          "$ref": "#/$defs/profiles"
        },
        "profile_gaps": {
          "$ref": "#/$defs/profileGaps"
        },
        "intent": {
          "$ref": "#/$defs/intent"
        },
        "task": {
          "$ref": "#/$defs/task"
        },
        "design_space": {
          "$ref": "#/$defs/designSpace"
        },
        "representation": {
          "$ref": "#/$defs/representation"
        },
        "environment": {
          "$ref": "#/$defs/environment"
        },
        "method_roles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/methodRole"
          }
        },
        "feedback_budget": {
          "$ref": "#/$defs/feedbackBudget"
        },
        "claims": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/claim"
          }
        },
        "evidence": {
          "$ref": "#/$defs/evidence"
        },
        "failed_or_rejected": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/failedOrRejected"
          }
        },
        "gates": {
          "description": "Predeclared pass/fail rejection checks. Each entry may reject a candidate or block a claim only under its recorded criterion and authority.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/gate"
          }
        },
        "decision_rights": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/decisionRight"
          }
        },
        "recommendation": {
          "$ref": "#/$defs/recommendation"
        },
        "accountable_decision": {
          "$ref": "#/$defs/accountableDecision"
        },
        "replay": {
          "$ref": "#/$defs/replay"
        },
        "independent_review": {
          "$ref": "#/$defs/independentReview"
        },
        "disclosure": {
          "$ref": "#/$defs/disclosure"
        }
      },
      "patternProperties": {
        "^x-[a-z0-9][a-z0-9.-]*$": {}
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "profiles": {
                "properties": {
                  "inspectability": {
                    "const": "partial"
                  }
                },
                "required": ["inspectability"]
              }
            },
            "required": ["profiles"]
          },
          "then": {
            "properties": {
              "profile_gaps": {
                "required": ["inspectability"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "profiles": {
                "properties": {
                  "replay": {
                    "const": "partial"
                  }
                },
                "required": ["replay"]
              }
            },
            "required": ["profiles"]
          },
          "then": {
            "properties": {
              "profile_gaps": {
                "required": ["replay"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "profiles": {
                "properties": {
                  "independent_review": {
                    "const": "partial"
                  }
                },
                "required": ["independent_review"]
              }
            },
            "required": ["profiles"]
          },
          "then": {
            "properties": {
              "profile_gaps": {
                "required": ["independent_review"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "profiles": {
                "properties": {
                  "disclosure": {
                    "const": "partial"
                  }
                },
                "required": ["disclosure"]
              }
            },
            "required": ["profiles"]
          },
          "then": {
            "properties": {
              "profile_gaps": {
                "required": ["disclosure"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "profiles": {
                "properties": {
                  "decision_rights": {
                    "const": "partial"
                  }
                },
                "required": ["decision_rights"]
              }
            },
            "required": ["profiles"]
          },
          "then": {
            "properties": {
              "profile_gaps": {
                "required": ["decision_rights"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "profiles": {
                "properties": {
                  "inspectability": {
                    "const": "complete"
                  }
                },
                "required": ["inspectability"]
              }
            },
            "required": ["profiles"]
          },
          "then": {
            "required": [
              "representation",
              "environment",
              "method_roles",
              "feedback_budget"
            ],
            "properties": {
              "method_roles": {
                "minItems": 1
              },
              "evidence": {
                "properties": {
                  "records": {
                    "minItems": 1
                  }
                }
              },
              "gates": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "profiles": {
                "properties": {
                  "replay": {
                    "const": "complete"
                  }
                },
                "required": ["replay"]
              }
            },
            "required": ["profiles"]
          },
          "then": {
            "required": ["replay"],
            "properties": {
              "replay": {
                "properties": {
                  "validation_status": {
                    "const": "replay_verified"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "profiles": {
                "properties": {
                  "independent_review": {
                    "const": "complete"
                  }
                },
                "required": ["independent_review"]
              }
            },
            "required": ["profiles"]
          },
          "then": {
            "required": ["independent_review"]
          }
        },
        {
          "if": {
            "properties": {
              "profiles": {
                "properties": {
                  "disclosure": {
                    "const": "complete"
                  }
                },
                "required": ["disclosure"]
              }
            },
            "required": ["profiles"]
          },
          "then": {
            "required": ["disclosure"]
          }
        },
        {
          "if": {
            "properties": {
              "profiles": {
                "properties": {
                  "decision_rights": {
                    "const": "complete"
                  }
                },
                "required": ["decision_rights"]
              }
            },
            "required": ["profiles"]
          },
          "then": {
            "properties": {
              "decision_rights": {
                "minItems": 6,
                "allOf": [
                  {
                    "contains": {
                      "properties": {
                        "action": {
                          "const": "propose"
                        }
                      },
                      "required": ["action"]
                    }
                  },
                  {
                    "contains": {
                      "properties": {
                        "action": {
                          "const": "execute"
                        }
                      },
                      "required": ["action"]
                    }
                  },
                  {
                    "contains": {
                      "properties": {
                        "action": {
                          "const": "reject"
                        }
                      },
                      "required": ["action"]
                    }
                  },
                  {
                    "contains": {
                      "properties": {
                        "action": {
                          "const": "waive"
                        }
                      },
                      "required": ["action"]
                    }
                  },
                  {
                    "contains": {
                      "properties": {
                        "action": {
                          "const": "recommend"
                        }
                      },
                      "required": ["action"]
                    }
                  },
                  {
                    "contains": {
                      "properties": {
                        "action": {
                          "const": "commit"
                        }
                      },
                      "required": ["action"]
                    }
                  }
                ]
              }
            }
          }
        }
      ]
    }
  }
}
