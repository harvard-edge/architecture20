#!/usr/bin/env python3
import argparse
import sys
import subprocess
from pathlib import Path

def check_refs():
    print("Running cross-reference checks...")
    # Delegate to the existing check_refs script for now, 
    # but we can fully integrate the logic here later.
    script_path = Path(__file__).parent / "scripts" / "check_refs.py"
    if not script_path.exists():
        script_path = Path(__file__).parent.parent / "scripts" / "check_refs.py"
    
    result = subprocess.run([sys.executable, str(script_path)])
    return result.returncode

def check_caps():
    print("Running capitalization checks...")
    script_path = Path(__file__).parent / "scripts" / "check_caps.py"
    if not script_path.exists():
        script_path = Path(__file__).parent.parent / "scripts" / "check_caps.py"
    
    result = subprocess.run([sys.executable, str(script_path)])
    return result.returncode

def check_formatting():
    print("Running AI formatting checks (this may take a while)...")
    script_path = Path(__file__).parent / "scripts" / "check_formatting.sh"
    if not script_path.exists():
        script_path = Path(__file__).parent.parent / "scripts" / "check_formatting.sh"
    
    result = subprocess.run(["bash", str(script_path)])
    return result.returncode

def check_all():
    print("Running all fast precommit checks...")
    codes = []
    codes.append(check_refs())
    codes.append(check_caps())
    # Note: check_formatting is excluded from 'all' because it runs AI agents and is too slow for a precommit hook.
    
    return max(codes) if codes else 0

def fix_refs():
    print("Running cross-reference auto-fixer...")
    script_path = Path(__file__).parent / "scripts" / "fix_sec_refs.py"
    if not script_path.exists():
        script_path = Path(__file__).parent.parent / "scripts" / "fix_sec_refs.py"
        
    result = subprocess.run([sys.executable, str(script_path)])
    return result.returncode

def main():
    parser = argparse.ArgumentParser(description="Architecture 2.0 CLI (arch2)")
    subparsers = parser.add_subparsers(dest="command", help="Available commands")

    # 'check' subcommand
    check_parser = subparsers.add_parser("check", help="Run validation checks on the manuscript")
    check_subparsers = check_parser.add_subparsers(dest="check_target", help="What to check")
    check_subparsers.add_parser("refs", help="Verify all figure and table cross-references")
    check_subparsers.add_parser("caps", help="Verify section title capitalization")
    check_subparsers.add_parser("formatting", help="Run AI formatting checks on chapters")
    check_subparsers.add_parser("all", help="Run all fast checks (suitable for precommit)")

    # 'fix' subcommand
    fix_parser = subparsers.add_parser("fix", help="Run auto-formatters and fixers")
    fix_subparsers = fix_parser.add_subparsers(dest="fix_target", help="What to fix")
    fix_subparsers.add_parser("refs", help="Auto-inject missing {#sec-xxx} tags for broken Quarto links")

    args = parser.parse_args()

    if args.command == "check":
        if args.check_target == "refs":
            sys.exit(check_refs())
        elif args.check_target == "caps":
            sys.exit(check_caps())
        elif args.check_target == "formatting":
            sys.exit(check_formatting())
        elif args.check_target == "all" or not args.check_target:
            sys.exit(check_all())
        else:
            check_parser.print_help()
    elif args.command == "fix":
        if args.fix_target == "refs":
            sys.exit(fix_refs())
        else:
            fix_parser.print_help()
    else:
        parser.print_help()

if __name__ == "__main__":
    main()
